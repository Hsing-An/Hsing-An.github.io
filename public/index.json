rgin: 1.2rem 0;\"\u003e\n  \u003ciframe width=\"100%\" height=\"250\" src=\"https://www.youtube.com/embed/ebeWruZ1ozk\" title=\"Polygatari-Matsuri\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen\u003e\u003c/iframe\u003e\n\u003c/div\u003e","description":"試著嘗試使用更多色彩的作品。","image":null,"permalink":"//localhost:1313/composition/atarayo/","title":"あたらよ(Atarayo)"},{"content":"\u003cdiv class=\"youtube-embed\" style=\"max-width:900px; margin: 1.2rem 0;\"\u003e\n  \u003ciframe width=\"100%\" height=\"250\" src=\"https://www.youtube.com/embed/avDgWoLj_Ao\" title=\"2-25\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen\u003e\u003c/iframe\u003e\n\u003c/div\u003e\n\u003cp\u003eA short piece written for recorder quintet, imitating the lively atmosphere of Chinese New Year.\nBlending fantasy and folk-ish styles, it features strong rhythmic patterns and non-functional harmonies to evoke a sense of Eastern mystery and celebration.\u003c/p\u003e","description":"我的木笛四重奏作品，嘗試融合奇幻、民俗風格。","image":null,"permalink":"//localhost:1313/composition/2-25/","title":"2-25"},{"content":"\u003cdiv class=\"youtube-embed\" style=\"max-width:900px; margin: 1.2rem 0;\"\u003e\n  \u003ciframe width=\"100%\" height=\"250\" src=\"https://www.youtube.com/embed/mwNRsrCOfXo\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen\u003e\u003c/iframe\u003e\n\u003c/div\u003e","description":"試著挑戰聽眾對於”相對剝奪感“的感受","image":null,"permalink":"//localhost:1313/composition/relative_deprivation/","title":"相對剝奪感 Relative Deprivation"},{"content":"\u003cdiv class=\"youtube-embed\" style=\"max-width:900px; margin: 1.2rem 0;\"\u003e\n  \u003ciframe width=\"100%\" height=\"250\" src=\"https://www.youtube.com/embed/fXnTvqZvXmY\" title=\"Polygatari-Matsuri\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen\u003e\u003c/iframe\u003e\n\u003c/div\u003e","description":"我的木笛二重奏作品，嘗試融合調性與非調性聲響。","image":null,"permalink":"//localhost:1313/composition/dialog/","title":"Dialog"},{"content":"\u003cdiv class=\"youtube-embed\" style=\"max-width:900px; margin: 1.2rem 0;\"\u003e\n  \u003ciframe width=\"100%\" height=\"250\" src=\"https://www.youtube.com/embed/uH10__FPMIs\" title=\"Polygatari-Matsuri\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen\u003e\u003c/iframe\u003e\n\u003c/div\u003e","description":null,"image":null,"permalink":"//localhost:1313/performance/articulator-i/","title":"Articulator I"},{"content":"\u003cdiv class=\"youtube-embed\" style=\"max-width:900px; margin: 1.2rem 0;\"\u003e\n  \u003ciframe width=\"100%\" height=\"250\" src=\"https://www.youtube.com/embed/_9IUzfO2Tac\" title=\"gurenge\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen\u003e\u003c/iframe\u003e\n\u003c/div\u003e","description":"改編鬼滅之刃主題曲——紅蓮華給木笛四重奏","image":null,"permalink":"//localhost:1313/composition/gurenge/","title":"紅蓮華(arrange for recorder quartet)"},{"content":"\u003cdiv class=\"youtube-embed\" style=\"max-width:900px; margin: 1.2rem 0;\"\u003e\n  \u003ciframe width=\"100%\" height=\"250\" src=\"https://www.youtube.com/embed/tmuQNh9m2mA\" title=\"gurenge\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen\u003e\u003c/iframe\u003e\n\u003c/div\u003e","description":"改編天氣之子主題曲——愛にできることはまだあるかい給木笛四重奏","image":null,"permalink":"//localhost:1313/composition/tenko-no-ko/","title":"愛にできることはまだあるかい(arrange for recorder quartet)"},{"content":"\u003cdiv class=\"youtube-embed\" style=\"max-width:900px; margin: 1.2rem 0;\"\u003e\n  \u003ciframe width=\"100%\" height=\"250\" src=\"https://www.youtube.com/embed/OvK7NOY7FsE\" title=\"gurenge\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen\u003e\u003c/iframe\u003e\n\u003c/div\u003e","description":"改編還願主題曲——碼頭姑娘給木笛四重奏","image":null,"permalink":"//localhost:1313/composition/devotion/","title":"碼頭姑娘(arrange for recorder quartet)"}]