{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
{{- $pages := .RegularPages -}}
{{- if .IsHome -}}
  {{- $pages = .Site.RegularPages -}}
{{- end -}}
{{- $limit := .Site.Config.Services.RSS.Limit -}}
{{- if ge $limit 1 -}}
  {{- $pages = first $limit $pages -}}
{{- end -}}
<rss version="2.0"
  xmlns:atom="http://www.w3.org/2005/Atom"
  xmlns:content="http://purl.org/rss/1.0/modules/content/">
  <channel>
    <title>{{ if eq .Title .Site.Title }}{{ .Site.Title | transform.XMLEscape }}{{ else }}{{ with .Title }}{{ . | transform.XMLEscape }} on {{ end }}{{ .Site.Title | transform.XMLEscape }}{{ end }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ with .Site.Params.description }}{{ . | transform.XMLEscape }}{{ else }}{{ .Site.Title | transform.XMLEscape }}{{ end }}</description>
    <generator>Hugo -- gohugo.io</generator>
    <language>{{ site.Language.LanguageCode }}</language>
    {{ with .Site.Copyright }}<copyright>{{ . | transform.XMLEscape }}</copyright>{{ end }}
    {{ if not .Date.IsZero }}<lastBuildDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>{{ end }}
    {{ with .OutputFormats.Get "RSS" -}}
      <atom:link href="{{ .Permalink }}" rel="self" type="{{ .MediaType.Type }}" />
    {{ end -}}
    {{ range $pages }}
    <item>
      <title>{{ .Title | transform.XMLEscape }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description>{{ .Summary | plainify | transform.XMLEscape }}</description>
      <content:encoded>{{ printf "<![CDATA[%s]]>" .Content | safeHTML }}</content:encoded>
    </item>
    {{ end }}
  </channel>
</rss>
